// Here are the signal interface implementations.
// port is for input signals, and connect is for output signal
port wclk {
    implement signal {
        // USER-TODO: implement wclk signal handling here.
        method signal_raise() {
        }
        method signal_lower() {
        }
    }
}
port wclk_en {
    implement signal {
        method signal_raise() {
            wclk_en_state = true;
            // If timer is enabled, reschedule event
            if (WatchdogRegisters.WDOGCONTROL.INTEN.val == 1) {
                counter_value.refresh();
                last_update_time = SIM_cycle_count(dev.obj);
                schedule_timeout();
            }
        }
        method signal_lower() {
            wclk_en_state = false;
            // Timer paused - cancel event
            if (timeout_event.posted()) {
                timeout_event.remove();
            }
        }
    }
}
port wrst_n {
    implement signal {
        method signal_raise() {
            // Reset signal deasserted (active low) - normal operation
        }
        method signal_lower() {
            // Reset signal asserted (active low) - reset device
            perform_reset();
        }
    }
}
port prst_n {
    implement signal {
        method signal_raise() {
            // Reset signal deasserted (active low) - normal operation
        }
        method signal_lower() {
            // Reset signal asserted (active low) - reset device
            perform_reset();
        }
    }
}
connect wdogint {
    interface signal;
    method signal_raise() {
        // CRITICAL: NULL check before calling signal methods
        if (this.obj != NULL) {
            this.signal.signal_raise();
        }
    }
    method signal_lower() {
        // CRITICAL: NULL check before calling signal methods
        if (this.obj != NULL) {
            this.signal.signal_lower();
        }
    }
}
