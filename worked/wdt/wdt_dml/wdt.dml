// Signal interface implementations. Ports model input signals into the device;
// connects model output signals the device drives. wclk is the watchdog clock
// input; because counting is modeled lazily, its edges need no handling.
port wclk {
    implement signal {
        // USER-TODO: implement wclk signal handling here.
        method signal_raise() {
        }
        method signal_lower() {
        }
    }
}
// wclk_en input (clock enable): raising it resumes counting (refreshes the
// counter and reschedules the event when enabled); lowering it pauses the timer
// by cancelling the pending countdown event.
port wclk_en {
    implement signal {
        method signal_raise() {
            wclk_en_state = true;
            // If timer is enabled, reschedule event
            if (WatchdogRegisters.WDOGCONTROL.INTEN.val == 1) {
                counter_value.refresh();
                last_update_time = SIM_cycle_count(dev.obj);
                schedule_timeout();
            }
        }
        method signal_lower() {
            wclk_en_state = false;
            // Timer paused - cancel event
            if (timeout_event.posted()) {
                timeout_event.remove();
            }
        }
    }
}
// wrst_n input (active-low watchdog reset): a falling edge performs a full
// device reset; the deasserted (high) level is normal operation.
port wrst_n {
    implement signal {
        method signal_raise() {
            // Reset signal deasserted (active low) - normal operation
        }
        method signal_lower() {
            // Reset signal asserted (active low) - reset device
            perform_reset();
        }
    }
}
// prst_n input (active-low power-on reset): a falling edge performs a full
// device reset; the deasserted (high) level is normal operation.
port prst_n {
    implement signal {
        method signal_raise() {
            // Reset signal deasserted (active low) - normal operation
        }
        method signal_lower() {
            // Reset signal asserted (active low) - reset device
            perform_reset();
        }
    }
}
// wdogint output: the watchdog interrupt line. Raises/lowers the connected
// signal with a NULL-object guard, so an unconnected interrupt is a no-op.
connect wdogint {
    interface signal;
    method signal_raise() {
        // CRITICAL: NULL check before calling signal methods
        if (this.obj != NULL) {
            this.signal.signal_raise();
        }
    }
    method signal_lower() {
        // CRITICAL: NULL check before calling signal methods
        if (this.obj != NULL) {
            this.signal.signal_lower();
        }
    }
}
// wdogres output: the watchdog reset line. Raises/lowers the connected signal
// with a NULL-object guard, so an unconnected reset is a no-op.
connect wdogres {
    interface signal;
    method signal_raise() {
        // CRITICAL: NULL check before calling signal methods
        if (this.obj != NULL) {
            this.signal.signal_raise();
        }
    }
    method signal_lower() {
        // CRITICAL: NULL check before calling signal methods
        if (this.obj != NULL) {
            this.signal.signal_lower();
        }
    }
}

