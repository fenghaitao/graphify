// Session variables for timer state management
saved cycles_t last_update_time;    // Last time counter was updated
saved bool interrupt_pending;       // Raw interrupt status
saved bool reset_pending;           // Reset signal status
saved bool is_locked;               // Lock state (true = locked, false = unlocked)
saved bool wclk_en_state;           // Clock enable signal state
saved bool first_enable;            // Track first enable for initialization
saved bool interrupt_signal_high;   // Track interrupt signal state
saved bool reset_signal_high;       // Track reset signal state

// Watchdog countdown event: fires when the counter reaches zero. On the first
// timeout it latches the interrupt and reloads the counter; on a second timeout
// (interrupt still pending) it asserts the reset signal when RESEN is enabled,
// then keeps reloading and counting.
event timeout_event is simple_cycle_event {
    method event() {
        // Counter has reached zero
        if (!interrupt_pending) {
            // First timeout - generate interrupt
            interrupt_pending = true;
            update_interrupt_signal();

            // Reload counter and reschedule
            counter_value.set_value(WatchdogRegisters.WDOGLOAD.val);
            last_update_time = SIM_cycle_count(dev.obj);
            schedule_timeout();
        } else {
            // Second timeout - generate reset if enabled
            if (WatchdogRegisters.WDOGCONTROL.RESEN.val == 1) {
                reset_pending = true;
                update_reset_signal();
            }

            // Continue reloading and counting
            counter_value.set_value(WatchdogRegisters.WDOGLOAD.val);
            last_update_time = SIM_cycle_count(dev.obj);
            schedule_timeout();
        }
    }
}

// Returns true while the device is locked. When locked, all register writes
// are ignored; the lock is cleared only by writing the magic unlock value
// 0x1ACCE551 to WDOGLOCK.
method is_device_locked() -> (bool) {
    return is_locked;
}

// Backing store for the watchdog down-counter. Holds the count and models it
// lazily: the live value is derived from elapsed cycles and the clock divider
// only when read, instead of being decremented every cycle.
attribute counter_value is (uint64_attr) {
    param init_val = 0xFFFFFFFF;
    // Resets the counter to its power-on value (0xFFFFFFFF).
    method reset() {
        this.val = init_val;
    }

    // Lazily computes the current count from the cycles elapsed since the last
    // update, scaled by the clock divider. Returns 0 once the counter has
    // underflowed, and the stored value while the timer is not running.
    method curr_value() -> (uint32) {
        if (WatchdogRegisters.WDOGCONTROL.INTEN.val == 0 || !wclk_en_state) {
            return this.val; // Timer not running
        }

        local cycles_t now = SIM_cycle_count(dev.obj);
        local cycles_t elapsed = now - this.val;
        local uint64 divider = get_divider();
        local uint64 decrements = elapsed / divider;

        if (decrements >= this.val) {
            return 0; // Counter has reached zero
        }

        return cast(this.val - decrements, uint32);
    }

    // Folds the lazily-computed live value back into the stored counter.
    method refresh() {
        this.val = curr_value(); // Update to current value based on elapsed time
    }

    // Stores a new counter value (used on reload and when freezing the counter).
    method set_value(uint64 new_val) {
        this.val = new_val;
    }

    // Returns the stored counter value without recomputing elapsed time.
    method get_value() -> (uint64) {
        return this.val;
    }
}

// Maps the WDOGCONTROL.STEP_VALUE field to the clock divider (1/2/4/8/16),
// defaulting to 1 for reserved encodings. The divider sets how many input
// clock cycles correspond to one decrement of the watchdog counter.
method get_divider() -> (uint64) {
    local uint64 step = WatchdogRegisters.WDOGCONTROL.STEP_VALUE.val;
    if (step == 0) return 1;
    if (step == 1) return 2;
    if (step == 2) return 4;
    if (step == 3) return 8;
    if (step == 4) return 16;
    return 1; // Default to 1 for invalid values
}

// (Re)posts the countdown event. Cancels any pending event, then, when the
// timer is enabled (INTEN set and clock running), schedules the event for the
// number of cycles until the counter reaches zero (remaining count * divider).
method schedule_timeout() {
    if (timeout_event.posted()) {
        timeout_event.remove();
    }

    local uint64 last_wdt_count = counter_value.get_value();
    if (WatchdogRegisters.WDOGCONTROL.INTEN.val == 1 && wclk_en_state && last_wdt_count > 0) {
        local uint64 divider = get_divider();
        local cycles_t cycles_to_zero = last_wdt_count * divider;
        timeout_event.post(cycles_to_zero);
    }
}

// Drives the WDOGINT output to match interrupt state: asserts when an interrupt
// is pending and INTEN is set, deasserts otherwise. Skipped in integration test
// mode, where WDOGITOP drives the signal directly.
method update_interrupt_signal() {
    local bool inten = WatchdogRegisters.WDOGCONTROL.INTEN.val == 1;
    local bool should_assert = interrupt_pending && inten;

    // Check if in test mode
    if (WatchdogRegisters.WDOGITCR.INT_TEST_MODE_ENABLE.val == 1) {
        return; // Don't update in test mode - WDOGITOP controls signals
    }

    // Only change signal if state changes
    if (should_assert && !interrupt_signal_high) {
        wdogint.signal_raise();
        interrupt_signal_high = true;
    } else if (!should_assert && interrupt_signal_high) {
        wdogint.signal_lower();
        interrupt_signal_high = false;
    }
}

// Drives the WDOGRES output to match reset state: asserts when a reset is
// pending, deasserts otherwise. Skipped in integration test mode, where
// WDOGITOP drives the signal directly.
method update_reset_signal() {
    // Check if in test mode
    if (WatchdogRegisters.WDOGITCR.INT_TEST_MODE_ENABLE.val == 1) {
        return; // Don't update in test mode - WDOGITOP controls signals
    }

    // Only change signal if state changes
    if (reset_pending && !reset_signal_high) {
        wdogres.signal_raise();
        reset_signal_high = true;
    } else if (!reset_pending && reset_signal_high) {
        wdogres.signal_lower();
        reset_signal_high = false;
    }
}


