// Common methods
method perform_reset() {
    // Cancel any pending timer events
    if (timeout_event.posted()) {
        timeout_event.remove();
    }

    // Reset all state variables
    counter_value.reset();
    last_update_time = 0;
    interrupt_pending = false;
    reset_pending = false;
    is_locked = false; // Device starts unlocked
    first_enable = true;

    // Reset all registers to their default values
    WatchdogRegisters.WDOGLOAD.val = 0xFFFFFFFF;
    WatchdogRegisters.WDOGCONTROL.val = 0x0;
    WatchdogRegisters.WDOGITCR.val = 0x0;

    // Lower all output signals
    wdogint.signal_lower();
    wdogres.signal_lower();
}

// Initialization
method init() {
    // Initialize state variables
    counter_value.reset();
    last_update_time = 0;
    interrupt_pending = false;
    reset_pending = false;
    is_locked = false; // Device starts unlocked
    wclk_en_state = true; // Assume clock enabled by default
    first_enable = true;
    interrupt_signal_high = false;
    reset_signal_high = false;
}
