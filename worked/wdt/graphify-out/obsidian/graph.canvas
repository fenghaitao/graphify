    {
      "id": "n_wdt_dml_wdt_rationale_186",
      "type": "file",
      "file": "Load register the value reloaded into the counter on each timeout and on interrupt clear. Writes are ignored while locked and do not reload the counter immediately unless INTEN transitions 0-1..md",
      "x": 3440,
      "y": 1580,
      "width": 180,
      "height": 60
    },
