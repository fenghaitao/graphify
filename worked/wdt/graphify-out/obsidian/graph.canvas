    },
    {
      "id": "n_wdt_dml_wdt_rationale_65",
      "type": "file",
      "file": "Backing store for the watchdog down-counter. Holds the count and models it lazily the live value is derived from elapsed cycles and the clock divider only when read, instead of being decremen_264d0e40.md",
      "x": 3240,
      "y": 80,
      "width": 180,
      "height": 60
    },
    {
      "id": "n_wdt_dml_wdt_rationale_95",
