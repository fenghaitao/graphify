{"nodes": [{"id": "raw_notes_keyword_extraction", "label": "Keyword Extraction", "file_type": "concept", "source_file": "raw/notes.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Current approach strips stopwords and returns unique tokens (simple and fast), but treats all keywords equally and cannot weight by position or distinctiveness."}, {"id": "raw_notes_tf_idf", "label": "TF-IDF Weighting", "file_type": "concept", "source_file": "raw/notes.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Term frequency times inverse document frequency gives higher scores to words distinctive to a document. Worth switching once the index is big enough (50+ documents) for IDF to be meaningful."}, {"id": "raw_notes_embedding_similarity", "label": "Embedding-based Similarity", "file_type": "concept", "source_file": "raw/notes.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Run each document through a sentence transformer, store the vector, do nearest-neighbor search at query time. Much better recall but adds a dependency and makes the index opaque; keyword approach is at least debuggable."}, {"id": "raw_notes_sqlite_migration", "label": "SQLite Migration", "file_type": "rationale", "source_file": "raw/notes.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "SQLite becomes worth it when you need range queries or to update individual fields without rewriting the whole record. The current save_processed rewrites the entire JSON file on every update, which is wasteful."}, {"id": "raw_notes_repository_pattern", "label": "Repository Pattern", "file_type": "rationale", "source_file": "raw/notes.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Parser, validator, and processor all import from storage directly. A repository pattern would centralize access but adds indirection. Probably not worth it until the storage backend needs to change."}, {"id": "raw_notes_transaction_risk", "label": "Transactional Write Risk", "file_type": "rationale", "source_file": "raw/notes.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "parse_and_save calls validate_document and save_parsed in sequence. If save_parsed fails after validate_document succeeds you get a partially written record. Not a problem at small scale, becomes a problem under load."}], "edges": [{"source": "raw_notes_keyword_extraction", "target": "raw_architecture_processor_module", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "raw/notes.md", "source_location": null, "weight": 1.0}, {"source": "raw_notes_keyword_extraction", "target": "raw_architecture_keyword_index", "relation": "conceptually_related_to", "confidence": "INFERRED", "confidence_score": 0.85, "source_file": "raw/notes.md", "source_location": null, "weight": 1.0}, {"source": "raw_notes_tf_idf", "target": "raw_notes_keyword_extraction", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "raw/notes.md", "source_location": null, "weight": 1.0}, {"source": "raw_notes_embedding_similarity", "target": "raw_notes_keyword_extraction", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "raw/notes.md", "source_location": null, "weight": 1.0}, {"source": "raw_notes_tf_idf", "target": "raw_notes_embedding_similarity", "relation": "semantically_similar_to", "confidence": "INFERRED", "confidence_score": 0.8, "source_file": "raw/notes.md", "source_location": null, "weight": 1.0}, {"source": "raw_notes_tf_idf", "target": "raw_architecture_cross_reference_detection", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "raw/notes.md", "source_location": null, "weight": 1.0}, {"source": "raw_notes_embedding_similarity", "target": "raw_architecture_cross_reference_detection", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "raw/notes.md", "source_location": null, "weight": 1.0}, {"source": "raw_notes_sqlite_migration", "target": "raw_architecture_storage_module", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "raw/notes.md", "source_location": null, "weight": 1.0}, {"source": "raw_notes_sqlite_migration", "target": "raw_architecture_flat_file_storage", "relation": "semantically_similar_to", "confidence": "INFERRED", "confidence_score": 0.85, "source_file": "raw/notes.md", "source_location": null, "weight": 1.0}, {"source": "raw_notes_repository_pattern", "target": "raw_architecture_storage_module", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "raw/notes.md", "source_location": null, "weight": 1.0}, {"source": "raw_notes_transaction_risk", "target": "raw_architecture_parser_module", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "raw/notes.md", "source_location": null, "weight": 1.0}, {"source": "raw_notes_transaction_risk", "target": "raw_architecture_linear_pipeline_design", "relation": "conceptually_related_to", "confidence": "INFERRED", "confidence_score": 0.75, "source_file": "raw/notes.md", "source_location": null, "weight": 1.0}], "hyperedges": [{"id": "keyword_relevance_alternatives", "label": "Keyword Relevance Approaches", "nodes": ["raw_notes_keyword_extraction", "raw_notes_tf_idf", "raw_notes_embedding_similarity"], "relation": "participate_in", "confidence": "INFERRED", "confidence_score": 0.8, "source_file": "raw/notes.md"}]}